{
	"name": "codekandis/constants-classes-translator",
	"description": "`codekandis/constants-classes-translator` is a library to translate values from constants classes into values of another constants classes.",
	"version": "2.0.0",
	"keywords": [
		"php",
		"constants classes translator",
		"constants",
		"constant",
		"classes",
		"class",
		"translator"
	],
	"minimum-stability": "stable",
	"prefer-stable": true,
	"license": "MIT",
	"authors": [
		{
			"name": "Christian Ramelow",
			"email": "info@codekandis.net",
			"homepage": "https://codekandis.net",
			"role": "Developer"
		}
	],
	"support": {
		"email": "info@codekandis.net",
		"issues": "https://github.com/codekandis/constants-classes-translator/issues",
		"docs": "https://github.com/codekandis/constants-classes-translator/blob/master/README.md",
		"source": "https://github.com/codekandis/constants-classes-translator/tree/master"
	},
	"require": {
		"php": ">=8.3"
	},
	"require-dev": {
		"roave/security-advisories": "dev-master",
		"codekandis/phpunit": "^5.0.0",
		"rector/rector": "^0.18.5"
	},
	"autoload": {
		"psr-4": {
			"CodeKandis\\ConstantsClassesTranslator\\": [
				"src/"
			]
		}
	},
	"autoload-dev": {
		"psr-4": {
			"CodeKandis\\ConstantsClassesTranslator\\Build\\": [
				"build/"
			],
			"CodeKandis\\ConstantsClassesTranslator\\Tests\\": [
				"tests/"
			]
		}
	}
}
